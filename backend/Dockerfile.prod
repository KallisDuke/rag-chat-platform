# syntax=docker/dockerfile:1

# Production image for the Express/TypeScript API.
# The app runs the TypeScript sources directly via `tsx` (the codebase imports
# with `.ts` extensions and tsconfig sets `noEmit`, so there is no `tsc` build
# step). `tsx` therefore lives in "dependencies", not "devDependencies".

# ---- deps: install production dependencies only ----
FROM node:22-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

# ---- runtime ----
FROM node:22-alpine AS runtime
ENV NODE_ENV=production
WORKDIR /app

# Production node_modules (includes tsx, excludes typescript and @types)
COPY --from=deps /app/node_modules ./node_modules
COPY package*.json ./
COPY tsconfig.json ./
COPY src ./src

EXPOSE 3000

# Run as the unprivileged user shipped with the node image
USER node

# Secrets/config are injected at runtime (MONGODB_URI, DB_NAME, COLLECTION_NAME,
# USER_COLLECTION_NAME, JWT_SECRET, OPENAI_API_KEY, optional PORT) — never baked in.
HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget -qO- "http://localhost:${PORT:-3000}/health" >/dev/null 2>&1 || exit 1

CMD ["node_modules/.bin/tsx", "src/server.ts"]
